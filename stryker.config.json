{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "reporters": [
    "html",
    "clear-text",
    "progress"
  ],
  "testRunner": "vitest",
  "testRunnerNodeArgs": [],
  "coverageAnalysis": "perTest",
  "mutate": [
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "!src/**/*.types.ts",
    "!src/index.ts",
    "!src/storybook.ts",
    "!src/browser.ts",
    "!src/capture.ts"
  ]
}
